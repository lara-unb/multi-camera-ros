# udev rules for Kinect - prevents kernel auto-binding and sets permissions
# Copy this file to /etc/udev/rules.d/ on the HOST machine
# Then run: sudo udevadm control --reload-rules && sudo udevadm trigger

# Xbox NUI Camera
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02ae", MODE="0666", ENV{ID_USB_INTERFACES}==":*"

# Xbox NUI Motor
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02b0", MODE="0666"

# Xbox NUI Audio
SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02ad", MODE="0666"

# Prevent automatic kernel driver binding (optional - use if unbind script doesn't work)
# SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02ae", ENV{ID_USB_DRIVER_UNBIND}="1"
# SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02b0", ENV{ID_USB_DRIVER_UNBIND}="1"
# SUBSYSTEM=="usb", ATTR{idVendor}=="045e", ATTR{idProduct}=="02ad", ENV{ID_USB_DRIVER_UNBIND}="1"
